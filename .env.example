# ─── 네이버 Open API ───
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ─── Google Custom Search API ───
# https://console.cloud.google.com 에서 API 키 발급
# https://programmablesearchengine.google.com 에서 검색엔진 ID 생성
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id

# ─── IndexNow ───
# 8~128자 영숫자+하이픈. 직접 생성하거나 Bing Webmaster Tools에서 발급
INDEXNOW_KEY=a1b2c3d4e5f6g7h8

# ─── 도메인 ───
DOMAIN=aidex.kr

# ─── Redis (Docker 내부) ───
REDIS_URL=redis://redis:6379/0

# ─── DB (SQLite) ───
DATABASE_URL=sqlite:///data/aidex.db
